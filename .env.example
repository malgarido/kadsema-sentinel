# ============================================================
# KADSEMA SENTINEL — environment configuration
# Copy this file to ".env" and fill in real values.
# ============================================================

# Data mode:
#   local     -> browser localStorage (default; no backend needed, great for demos)
#   supabase  -> live PostgreSQL/PostGIS backend (Phase 1)
VITE_DATA_MODE=local

# Required only when VITE_DATA_MODE=supabase
# Get these from Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
